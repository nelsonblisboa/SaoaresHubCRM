# SOARES HUB — Instagram Service Environment Variables

# Credenciais da conta Instagram usada para prospecção
INSTAGRAM_USERNAME=sua_conta_instagram
INSTAGRAM_PASSWORD=sua_senha_instagram

# Supabase (service role para bypass de RLS durante sync)
SUPABASE_URL=https://joxsdkjbbvdjzelxjnxk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ID da organização padrão para sync de contatos
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

# Porta do serviço
PORT=8000
